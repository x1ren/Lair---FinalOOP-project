@startuml
skinparam classAttributeIconSize 0
skinparam packageStyle rectangle

package "org.example" {
  class Main
}

package "org.example.ui" {
  class IntroScene
  class CharacterSelectScene
  class GameScene
}

package "org.example.player" {
  enum CharacterType
}

package "org.example.app" {
  class GameContext
}

package "org.example.assets" {
  class AssetRegistry
  class AssetPreloader
  class SpriteSheet
  class SpriteSet
  enum AnimationState
}

package "org.example.audio" {
  class AudioManager
}

package "org.example.engine" {
  abstract class GameLoop
  class InputHandler
  class CollisionManager
}

package "org.example.gameplay" {
  abstract class GameObject
  class PlayerActor
  class EnemyActor
  class Projectile
  class PlatformTile
  class StageDefinition
  class StageCatalog
  class "EntityManager<T extends GameObject>" as EntityManager
}

package "org.example.weapons" {
  class Weapon
  class WeaponCatalog
  enum WeaponType
}

Main --> GameContext
GameContext --> IntroScene
GameContext --> CharacterSelectScene
GameContext --> GameScene
GameContext --> AssetRegistry
GameContext --> AudioManager
GameContext --> AssetPreloader
IntroScene --> CharacterSelectScene
CharacterSelectScene --> GameScene

GameScene --> CharacterType
GameScene --> Weapon
GameScene --> InputHandler
GameScene --> CollisionManager
GameScene --> GameLoop
GameScene --> PlayerActor
GameScene --> EnemyActor
GameScene --> Projectile
GameScene --> PlatformTile
GameScene --> StageCatalog
GameScene --> StageDefinition
GameScene --> EntityManager
GameScene --> AssetRegistry
GameScene --> AudioManager
GameScene --> SpriteSet

PlayerActor --|> GameObject
EnemyActor --|> GameObject
Projectile --|> GameObject
PlatformTile --|> GameObject

EntityManager ..> GameObject
EnemyActor --> PlayerActor
CharacterType --> WeaponCatalog
CharacterType --> WeaponType

AssetRegistry --> SpriteSheet
SpriteSet --> SpriteSheet
SpriteSet --> AnimationState
WeaponCatalog --> Weapon
Weapon --> WeaponType

@enduml
