@startuml
left to right direction
skinparam packageStyle rectangle
skinparam actorStyle awesome

actor Player

rectangle "THE LAIR Game System" {
  usecase "Start New Game" as UC_Start
  usecase "View Story Intro" as UC_Intro
  usecase "Select Character" as UC_SelectCharacter
  usecase "Play Game" as UC_Play
  usecase "Explore Campus" as UC_Explore
  usecase "Fight Enemies" as UC_FightEnemies
  usecase "Fight Boss" as UC_FightBoss
  usecase "Fight Caesar Hunos" as UC_Caesar
  usecase "Fight False Sir Khai" as UC_Khai
  usecase "Use Character Skill" as UC_Skill
  usecase "Reload Weapon" as UC_Reload
  usecase "View Ending" as UC_Ending
  usecase "Exit Game" as UC_Exit
}

Player -- UC_Start
Player -- UC_Play
Player -- UC_Exit

UC_Start ..> UC_Intro : <<include>>
UC_Start ..> UC_SelectCharacter : <<include>>

UC_Play ..> UC_Explore : <<include>>
UC_Play ..> UC_FightEnemies : <<include>>
UC_Play ..> UC_FightBoss : <<include>>
UC_Play ..> UC_Ending : <<include>>

UC_Skill ..> UC_FightEnemies : <<extend>>
UC_Reload ..> UC_FightEnemies : <<extend>>

UC_Caesar -|> UC_FightBoss
UC_Khai -|> UC_FightBoss

@enduml
